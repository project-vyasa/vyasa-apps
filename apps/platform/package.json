{
	"name": "@project-vyasa/platform",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"deploy": "vite build && gh-pages -d build --dotfiles --nojekyll"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@project-vyasa/vyasa-compiler-wasm": "file:../../../vyasa/vyasac/pkg",
		"@project-vyasa/vyasa-ui": "file:../../../vyasa-ui/svelte",
		"@project-vyasa/vyasa-viewer-wasm": "file:../../../vyasa/vyasav/pkg",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^22",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"gh-pages": "^6.3.0",
		"globals": "^17.6.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16"
	},
	"dependencies": {
		"lucide-svelte": "^1.0.1",
		"wa-sqlite": "^1.0.0"
	}
}
